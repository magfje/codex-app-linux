{
  "name": "codex-app-linux-publisher",
  "private": true,
  "version": "0.0.0",
  "description": "Build and publish Linux Codex desktop app repacks.",
  "author": "Zero Caulk <zero@composer.group>",
  "type": "module",
  "scripts": {
    "canary": "node scripts/canary.mjs",
