    "release:beta": "node scripts/release-channel.mjs --channel beta"
  },
  "devDependencies": {
    "@electron/asar": "4.1.0",
    "@electron/rebuild": "4.0.3",
    "acorn": "8.15.0",
    "electron": "42.1.0",
    "electron-builder": "26.8.1",
    "playwright": "1.61.0",
    "ws": "8.20.0"
  }
}
